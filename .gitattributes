# Normalize line endings to LF in the repository
* text=auto eol=lf

# Explicitly mark HTML/CSS/JS as text
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.ts   text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Binary files — never modify
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff binary
*.woff2 binary
